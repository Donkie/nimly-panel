# ---- HTTP -----------------------------------------------------------------
ADDR=:8080
# Public URL the panel is reached at (used for OIDC redirect + post-login).
APP_BASE_URL=https://lock.example.com
# Set to true ONLY for local http development (relaxes the Secure cookie flag).
DEV_MODE=false

# ---- MQTT broker ----------------------------------------------------------
# tcp:// for plain, tls:// for TLS, ws:// / wss:// also supported by paho.
MQTT_BROKER_URL=tcp://mqtt.example.lan:1883
MQTT_USERNAME=nimlypanel
MQTT_PASSWORD=change-me
MQTT_CLIENT_ID=nimlypanel
# Zigbee2MQTT base topic for the lock (friendly name). Mind the exact spelling.
MQTT_LOCK_TOPIC=zigbee2mqtt/Front Door Lock

# ---- OIDC (PocketID) ------------------------------------------------------
# Issuer is your PocketID base URL (discovery at {issuer}/.well-known/openid-configuration).
OIDC_ISSUER=https://id.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Defaults to {APP_BASE_URL}/api/auth/callback if left empty.
OIDC_REDIRECT_URL=https://lock.example.com/api/auth/callback
OIDC_SCOPES=openid,profile,email,groups
# Optional allowlist. Leave empty to allow any successfully authenticated user.
# ALLOWED_GROUPS=lock-admins
# ALLOWED_SUBS=

# ---- Session --------------------------------------------------------------
# Must be >= 32 bytes. Generate with: openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-bytes
SESSION_LIFETIME=12h
SESSION_IDLE_TIMEOUT=1h

# ---- Audit (optional) -----------------------------------------------------
# If set, audit entries are also appended as JSON lines to this file.
# AUDIT_LOG_PATH=/data/audit.jsonl
